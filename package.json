{
  "name": "miseos-back-of-house",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node -e \"require('fs').rmSync('node_modules/.vite', { recursive: true, force: true })\" && cross-env NODE_ENV=development tsx server.ts",
    "build": "vite build",
    "start": "node -e \"try { require('fs').rmSync('dist', { recursive: true, force: true }); require('fs').rmSync('.vite', { recursive: true, force: true }); } catch(e) {}\" && npm run build && cross-env NODE_ENV=production tsx server.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  }
}
