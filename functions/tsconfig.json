{
  "compilerOptions": {
    "module": "NodeNext",
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "outDir": "lib",
    "sourceMap": true,
    "target": "es2020",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"]
    },
    "rootDir": "./src"
  },
  "include": [
    "src"
  ]
}