{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitAny": false,
    "removeComments": true,
    "preserveConstEnums": true,
    "outDir": "lib",
    "sourceMap": true,
    "target": "es2020",
    "moduleResolution": "node",
    "paths": {
      "@/*": ["./src/*"]
    },
    "rootDir": "./src"
  },
  "include": [
    "src"
  ]
}