rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Single-operator app: one authenticated chef account (created once in
    // the Firebase console — no self-registration). Every collection below
    // requires request.auth != null for all reads and writes; there is no
    // per-document ownership or role hierarchy to enforce because there is
    // only ever one signed-in identity.
    //
    // Collection: prepItems      — see src/types.ts PrepItem
    // Collection: recipes        — see src/types.ts Recipe / RecipeLine
    // Collection: items86        — see src/types.ts Item86
    // Collection: features       — see src/types.ts Feature
    // Collection: staff          — see src/types.ts Employee
    // Collection: shifts         — see src/types.ts Shift
    // Collection: events         — see src/types.ts KitchenEvent
    // Collection: alerts         — see src/types.ts KitchenAlert
    // Collection: crib_notes     — see src/types.ts CribNote
    // Collection: timers         — see src/types.ts KitchenTimer
    // Collection: station_presets  — { name: string }
    // Collection: recipe_categories — see src/types.ts RecipeCategory
    // Collection: event_types    — see src/types.ts EventTypePreset
    // Collection: clients        — see src/types.ts Client
    // Collection: ingredients    — see src/types.ts Ingredient (shape-validated below)
    // Collection: vendors        — see src/types.ts Vendor
    // Collection: restaurant_profile — see src/types.ts RestaurantProfile;
    //   singleton doc at a fixed id ("main"), not a growing collection
    // Collection: trend_reports  — see src/types.ts TrendReport; singleton
    //   doc at a fixed id ("latest"), not a growing collection. Read-only
    //   editorial content — see Test Kitchen Phase B's hard boundary in
    //   CLAUDE.md: never written to by any pantry/costing code path.
    //
    // Ingredient fields (src/types.ts):
    //   - name: string (required, 1-200 chars)
    //   - category: string (required) — IngredientCategory enum
    //   - measureType: string (required) — 'weight' | 'volume' | 'each'
    //   - purchaseUnit: string (required, <= 100 chars)
    //   - purchaseCost: number (required, >= 0)
    //   - purchaseQty: number (required, >= 0)
    //   - yieldPercent: number (required, 0-100)
    //   - lastVerified: string (required) — ISO date, set on every write
    //   - priceSource: string (required) — 'regional-estimate' | 'invoice' | 'manual'
    //   - nutritionPer100g: map (optional)
    //   - allergens: list (optional, <= 20 items)
    //   - vendorId: string (optional) — id reference into vendors
    //   - nutritionSource: string (optional) — 'ai' | 'manual'
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidIngredient(data) {
      let required = ['name', 'category', 'measureType', 'purchaseUnit', 'purchaseCost', 'purchaseQty', 'yieldPercent', 'lastVerified', 'priceSource'];
      let optional = ['nutritionPer100g', 'allergens', 'vendorId', 'nutritionSource'];
      return data.keys().hasAll(required)
        && data.keys().hasOnly(required.concat(optional))
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.category is string
        && data.category in ['Produce', 'Protein', 'Dairy', 'Dry Goods', 'Frozen', 'Beverage', 'Other', 'Spices', 'Oils & Fats', 'Sauces', 'Beverages', 'Bakery']
        && data.measureType is string && data.measureType in ['weight', 'volume', 'each']
        && data.purchaseUnit is string && data.purchaseUnit.size() <= 100
        && data.purchaseCost is number && data.purchaseCost >= 0
        && data.purchaseQty is number && data.purchaseQty >= 0
        && data.yieldPercent is number && data.yieldPercent >= 0 && data.yieldPercent <= 100
        && data.lastVerified is string
        && data.priceSource is string && data.priceSource in ['regional-estimate', 'invoice', 'manual']
        && (!('vendorId' in data) || (data.vendorId is string && data.vendorId.size() <= 200))
        && (!('allergens' in data) || (data.allergens is list && data.allergens.size() <= 20))
        && (!('nutritionPer100g' in data) || data.nutritionPer100g is map)
        && (!('nutritionSource' in data) || data.nutritionSource in ['ai', 'manual']);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================
    //
    // Everything except `ingredients` is a plain authenticated-read/write
    // gate — the only real threat model for a single-operator internal tool
    // is an unauthenticated stranger hitting the database directly, not the
    // one signed-in chef corrupting their own data. `ingredients` gets a
    // full shape validator on top because invoice-extracted and AI-suggested
    // data flows into it (see components/ingredients/InvoicePriceUpdate.tsx).

    match /prepItems/{id}          { allow read, write: if isAuthenticated(); }
    match /recipes/{id}            { allow read, write: if isAuthenticated(); }
    match /items86/{id}            { allow read, write: if isAuthenticated(); }
    match /features/{id}           { allow read, write: if isAuthenticated(); }
    match /staff/{id}               { allow read, write: if isAuthenticated(); }
    match /shifts/{id}              { allow read, write: if isAuthenticated(); }
    match /events/{id}              { allow read, write: if isAuthenticated(); }
    match /alerts/{id}              { allow read, write: if isAuthenticated(); }
    match /crib_notes/{id}          { allow read, write: if isAuthenticated(); }
    match /timers/{id}               { allow read, write: if isAuthenticated(); }
    match /station_presets/{id}     { allow read, write: if isAuthenticated(); }
    match /recipe_categories/{id}   { allow read, write: if isAuthenticated(); }
    match /recipe_collections/{id}  { allow read, write: if isAuthenticated(); }
    match /event_types/{id}         { allow read, write: if isAuthenticated(); }
    match /clients/{id}             { allow read, write: if isAuthenticated(); }
    match /vendors/{id}              { allow read, write: if isAuthenticated(); }
    match /restaurant_profile/{id}   { allow read, write: if isAuthenticated(); }
    match /trend_reports/{id}        { allow read, write: if isAuthenticated(); }

    match /ingredients/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidIngredient(request.resource.data);
      allow update: if isAuthenticated() && isValidIngredient(request.resource.data);
      allow delete: if isAuthenticated();
    }

    // Default deny for anything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
