rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny all access.
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow authenticated users to read station presets for UI population.
    match /station_presets/{presetId} {
      allow read: if request.auth != null;
    }

    // Allow authenticated users to read trend reports.
    match /trend_reports/{reportId} {
      allow read: if request.auth != null;
    }

    // Rules for handover logs.
    match /handover_logs/{logId} {
      // Anyone authenticated can create a handover log, provided the data is valid.
      // The `submitted_by_uid` should be the UID of the user creating the log.
      allow create: if request.auth != null && isValidHandoverLog(request.resource.data);

      // Only the user who created the log can update it.
      // This assumes a 'submitted_by_uid' field is stored on the document.
      allow update: if request.auth.uid == resource.data.submitted_by_uid && isValidHandoverLog(request.resource.data);

      // Allow any authenticated user to read logs.
      allow read: if request.auth != null;
    }

    // Helper function to validate the structure of a handover log document.
    function isValidHandoverLog(data) {
      return data.shift_id is string
        && data.station is string
        && data.status in ['pass', 'fail', 'incomplete']
        && data.notes is string
        && data.items86 is list
        && data.submitted_by is string
        && data.submitted_by_uid == request.auth.uid // Enforce creator UID
        && data.timestamp == request.time; // Enforce server timestamp
    }
  }
}
