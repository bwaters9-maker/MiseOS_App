rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: brain_dumps
    // Document ID: auto-generated
    // Fields:
    //   - note_content: string (required, 1-5000 chars) - The raw text content of the note.
    //   - created_at: timestamp (required, server-set) - The time the note was logged.
    //   - processed: boolean (required, must be false) - A flag for later processing.
    //
    // ===============================================================


    // ===============================================================
    // Helper Functions
    // ===============================================================

    /**
     * Check if the user is authenticated.
     */
    function isAuthenticated() {
      return request.auth != null;
    }

    /**
     * Validate that the document contains only the allowed fields.
     * This prevents schema pollution with arbitrary data.
     */
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    /**
     * Validates the structure and content of a new brain_dump document.
     * This is the quality check for every note dropped on the spike.
     */
    function isValidBrainDump() {
      let data = request.resource.data;
      return hasOnlyAllowedFields(['note_content', 'created_at', 'processed']) &&
             data.note_content is string &&
             data.note_content.size() > 0 &&
             data.note_content.size() < 5000 && // Protects against abuse
             data.created_at == request.time && // Ensures timestamp is set by the server
             data.processed == false; // Must always start as unprocessed
    }


    // ===============================================================
    // Collection Rules
    // ===============================================================

    /**
     * brain_dumps: A write-only collection for raw notes.
     * - CREATE: Any authenticated user can create a new note.
     * - READ, UPDATE, DELETE: Are all disallowed to ensure a tamper-proof log.
     */
    match /brain_dumps/{dumpId} {
      allow create: if isAuthenticated() && isValidBrainDump();
      allow read, update, delete: if false;
    }

    // Fallback rule: Deny all other access by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}